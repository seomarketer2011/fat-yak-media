---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { SITE } from '../data/site';
import mapPin from '../assets/images/map-pin-blue.png';
---

<Base
  title={`Contact — ${SITE.name}`}
  description="Get your free local SEO audit. Tell us about your business and we'll show you exactly how to get found by more customers."
>
  <section class="bg-navy-950 py-16">
    <div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
      <p class="text-sm font-bold uppercase tracking-widest text-teal-400">Contact</p>
      <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
        Let’s get you found
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-navy-200">
        Tell us about your business and we’ll send back a free audit: where you rank, what’s holding you
        back, and what we’d do about it. No obligation, no hard sell.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto grid max-w-6xl gap-12 px-4 sm:px-6 lg:grid-cols-2">
      <form
        class="rounded-2xl border border-navy-100 bg-white p-8 shadow-sm"
        action={`mailto:${SITE.email}`}
        method="post"
        enctype="text/plain"
      >
        <h2 class="text-xl font-extrabold text-navy-900">Request your free SEO audit</h2>
        <div class="mt-6 grid gap-5 sm:grid-cols-2">
          <label class="block text-sm font-semibold text-navy-800">
            Name
            <input
              type="text"
              name="name"
              required
              class="mt-1.5 w-full rounded-lg border border-navy-200 px-3.5 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
            />
          </label>
          <label class="block text-sm font-semibold text-navy-800">
            Email
            <input
              type="email"
              name="email"
              required
              class="mt-1.5 w-full rounded-lg border border-navy-200 px-3.5 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
            />
          </label>
          <label class="block text-sm font-semibold text-navy-800 sm:col-span-2">
            Business name & website
            <input
              type="text"
              name="business"
              class="mt-1.5 w-full rounded-lg border border-navy-200 px-3.5 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
            />
          </label>
          <label class="block text-sm font-semibold text-navy-800 sm:col-span-2">
            What would you like help with?
            <textarea
              name="message"
              rows="4"
              class="mt-1.5 w-full rounded-lg border border-navy-200 px-3.5 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200"
            ></textarea>
          </label>
        </div>
        <button
          type="submit"
          class="mt-6 w-full rounded-full bg-amber-500 px-7 py-3.5 text-base font-bold text-navy-950 shadow transition hover:bg-amber-400"
        >
          Send my audit request
        </button>
        <p class="mt-3 text-center text-xs text-navy-600">
          Prefer email? Write to <a href={`mailto:${SITE.email}`} class="font-semibold text-brand-600">{SITE.email}</a>
        </p>
      </form>

      <div>
        <div class="flex items-start gap-4">
          <Image src={mapPin} alt="" width="40" height="55" class="h-12 w-auto" />
          <div>
            <h2 class="text-xl font-extrabold text-navy-900">Service area</h2>
            <p class="mt-2 text-base leading-7 text-navy-700">
              We work with local businesses across {SITE.areaServed} — cafés and clinics, tradies and
              retailers, single locations and multi-site operators. If your customers search locally,
              we can help you get found.
            </p>
          </div>
        </div>
        <div class="mt-10 rounded-2xl bg-navy-50/70 p-8">
          <h3 class="text-lg font-bold text-navy-900">What happens next?</h3>
          <ol class="mt-4 space-y-4 text-sm leading-6 text-navy-700">
            <li class="flex gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-500 text-xs font-extrabold text-white">1</span>
              We review your website, rankings and Google Business Profile.
            </li>
            <li class="flex gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-500 text-xs font-extrabold text-white">2</span>
              You get a short, plain-English audit with the biggest opportunities.
            </li>
            <li class="flex gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-500 text-xs font-extrabold text-white">3</span>
              If it makes sense, we quote. If not, you keep the audit — no strings.
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>
</Base>

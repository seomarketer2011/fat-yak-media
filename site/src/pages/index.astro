---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CtaBand from '../components/CtaBand.astro';
import { SERVICES } from '../data/services';
import { SITE } from '../data/site';

import heroIllus from '../assets/images/illus-seo-wide.jpg';
import researchIllus from '../assets/images/illus-research-wide.jpg';
import strategyIllus from '../assets/images/illus-strategy.jpg';
import missionIllus from '../assets/images/illus-mission.jpg';
import analyticsIllus from '../assets/images/illus-analytics.jpg';
import partnersIllus from '../assets/images/illus-partners.jpg';
import mapPin from '../assets/images/map-pin-blue.png';
import avatar1 from '../assets/images/avatar-1.jpg';
import avatar2 from '../assets/images/avatar-2.jpg';
import avatar3 from '../assets/images/avatar-3.jpg';

const stats = [
  { value: '312%', label: 'average increase in organic enquiries' },
  { value: 'Top 3', label: 'map-pack rankings for core keywords' },
  { value: '<1s', label: 'load time on the sites we build' },
  { value: '0', label: 'lock-in contracts. Ever.' },
];

const steps = [
  {
    title: 'Research',
    image: researchIllus,
    text: 'We audit your site, your competitors and the searches your customers make, so every move is backed by data.',
  },
  {
    title: 'Strategy',
    image: strategyIllus,
    text: 'You get a plain-English plan with priorities, timelines and forecasts — no jargon, no fluff.',
  },
  {
    title: 'Execute',
    image: missionIllus,
    text: 'Our team does the work: technical fixes, content, citations, links, ads. You watch the rankings move.',
  },
  {
    title: 'Report & refine',
    image: analyticsIllus,
    text: 'Monthly reports show enquiries and revenue, not vanity metrics. We double down on what works.',
  },
];

const testimonials = [
  {
    avatar: avatar1,
    name: 'Sarah M.',
    role: 'Café owner',
    quote:
      'We went from invisible to the top of the map pack in three months. Weekend bookings have never been stronger.',
  },
  {
    avatar: avatar2,
    name: 'Dave T.',
    role: 'Plumbing contractor',
    quote:
      'The phone rings with real jobs now, not tyre-kickers. Best marketing money I have ever spent — and I can read the reports.',
  },
  {
    avatar: avatar3,
    name: 'Priya K.',
    role: 'Physiotherapy clinic',
    quote:
      'New site loads instantly, ranks for every suburb we serve, and new-patient enquiries are up 3x since launch.',
  },
];

const faqs = [
  {
    q: 'What is local SEO?',
    a: 'Local SEO is the practice of optimising your online presence — your website, Google Business Profile, reviews and citations — so your business shows up when nearby customers search for what you offer.',
  },
  {
    q: 'How much does SEO cost?',
    a: 'Campaigns are scoped to your market and goals. Local campaigns for single-location businesses start smaller; competitive multi-location campaigns need more. Your free audit comes with a clear, fixed quote.',
  },
  {
    q: 'How is Fat Yak Media different from other agencies?',
    a: 'No lock-in contracts, plain-English reporting tied to enquiries and revenue, and every site we build is static-first and blisteringly fast. We win by results, not by contracts.',
  },
  {
    q: 'Do you only work with businesses in Australia?',
    a: 'We work with local businesses anywhere, with a focus on Australian markets. Local SEO fundamentals travel well — if your customers search locally, we can help.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title={`${SITE.name} — ${SITE.tagline}`}
  schema={faqSchema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-navy-950">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(123,108,154,0.35),transparent_60%)]"></div>
    <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-4 py-20 sm:px-6 lg:grid-cols-2 lg:py-28">
      <div>
        <p class="inline-flex items-center gap-2 rounded-full border border-brand-400/40 bg-brand-500/10 px-4 py-1.5 text-sm font-semibold text-brand-200">
          <Image src={mapPin} alt="" width="16" height="16" class="h-4 w-auto" />
          Local SEO specialists
        </p>
        <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl">
          Get found first when locals search for what you do
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-8 text-navy-200">
          Fat Yak Media puts local businesses at the top of Google — the map pack, the organic results and the ads.
          More visibility, more calls, more customers through your door.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contact/"
            class="rounded-full bg-amber-500 px-7 py-3.5 text-base font-bold text-navy-950 shadow-lg transition hover:bg-amber-400"
          >
            Get a free SEO audit
          </a>
          <a
            href="/services/"
            class="rounded-full border border-navy-400 px-7 py-3.5 text-base font-bold text-white transition hover:border-white hover:bg-white/10"
          >
            Explore services
          </a>
        </div>
        <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm font-semibold text-navy-300">
          <li class="flex items-center gap-2"><span class="text-teal-400">✓</span> No lock-in contracts</li>
          <li class="flex items-center gap-2"><span class="text-teal-400">✓</span> Plain-English reporting</li>
          <li class="flex items-center gap-2"><span class="text-teal-400">✓</span> Results in 90 days</li>
        </ul>
      </div>
      <div class="relative">
        <div class="overflow-hidden rounded-3xl shadow-2xl ring-1 ring-white/10">
          <Image
            src={heroIllus}
            alt="Illustration of search engine optimisation: rankings graph climbing under a magnifying glass"
            width="700"
            loading="eager"
            fetchpriority="high"
            class="h-auto w-full"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-navy-100 bg-white">
    <dl class="mx-auto grid max-w-6xl grid-cols-2 gap-8 px-4 py-12 text-center sm:px-6 lg:grid-cols-4">
      {
        stats.map((s) => (
          <div>
            <dt class="text-3xl font-extrabold text-brand-600 sm:text-4xl">{s.value}</dt>
            <dd class="mt-1 text-sm font-medium text-navy-700">{s.label}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- Services -->
  <section class="bg-navy-50/50 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-bold uppercase tracking-widest text-teal-600">What we do</p>
        <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-navy-900 sm:text-4xl">
          Digital marketing that pays for itself
        </h2>
        <p class="mt-4 text-lg text-navy-700">
          Six services, one goal: more customers for your business. Start with one or combine them into a
          full local growth engine.
        </p>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {SERVICES.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-bold uppercase tracking-widest text-teal-600">How we work</p>
        <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-navy-900 sm:text-4xl">
          A proven four-step process
        </h2>
      </div>
      <ol class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((step, i) => (
            <li class="relative rounded-2xl border border-navy-100 bg-white p-6 shadow-sm">
              <span class="absolute -top-4 left-6 flex h-8 w-8 items-center justify-center rounded-full bg-brand-500 text-sm font-extrabold text-white">
                {i + 1}
              </span>
              <Image src={step.image} alt="" width="400" height="400" class="mx-auto h-32 w-32 rounded-xl object-cover" />
              <h3 class="mt-4 text-lg font-bold text-navy-900">{step.title}</h3>
              <p class="mt-2 text-sm leading-6 text-navy-700">{step.text}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Local SEO feature -->
  <section class="bg-navy-950 py-20">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2">
      <div class="order-2 lg:order-1">
        <div class="overflow-hidden rounded-3xl shadow-2xl ring-1 ring-white/10">
          <Image
            src={partnersIllus}
            alt="Illustration of a business partnership handshake"
            width="600"
            class="h-auto w-full"
          />
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <p class="text-sm font-bold uppercase tracking-widest text-teal-400">Why local SEO</p>
        <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          46% of Google searches have local intent
        </h2>
        <p class="mt-4 text-lg leading-8 text-navy-200">
          When someone searches “plumber near me” or “best café open now”, Google shows a map and three
          businesses. If you’re not one of them, your competitor gets the call. We make sure it’s you.
        </p>
        <ul class="mt-6 space-y-3 text-navy-100">
          <li class="flex gap-3"><span class="mt-1 text-teal-400">✓</span> Google Business Profile optimised and actively managed</li>
          <li class="flex gap-3"><span class="mt-1 text-teal-400">✓</span> Consistent citations across every directory that matters</li>
          <li class="flex gap-3"><span class="mt-1 text-teal-400">✓</span> A steady stream of five-star reviews</li>
          <li class="flex gap-3"><span class="mt-1 text-teal-400">✓</span> Suburb pages that rank for every area you serve</li>
        </ul>
        <a
          href="/services/local-seo/"
          class="mt-8 inline-block rounded-full bg-teal-500 px-7 py-3.5 text-base font-bold text-white transition hover:bg-teal-600"
        >
          See our local SEO service
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-bold uppercase tracking-widest text-teal-600">Results</p>
        <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-navy-900 sm:text-4xl">
          Local businesses, real growth
        </h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          testimonials.map((t) => (
            <figure class="flex flex-col rounded-2xl border border-navy-100 bg-white p-7 shadow-sm">
              <svg class="h-8 w-8 text-brand-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M9.6 4.8C6 7 4 10.2 4 14.1c0 3 1.8 5.1 4.3 5.1 2.2 0 3.9-1.7 3.9-3.9 0-2.1-1.5-3.7-3.6-3.7h-.6c.5-2 2-3.9 4-5.2L9.6 4.8zm10 0C16 7 14 10.2 14 14.1c0 3 1.8 5.1 4.3 5.1 2.2 0 3.9-1.7 3.9-3.9 0-2.1-1.5-3.7-3.6-3.7h-.6c.5-2 2-3.9 4-5.2l-2.4-1.6z" />
              </svg>
              <blockquote class="mt-4 flex-1 text-sm leading-7 text-navy-800">“{t.quote}”</blockquote>
              <figcaption class="mt-6 flex items-center gap-3">
                <Image src={t.avatar} alt="" width="96" height="96" class="h-11 w-11 rounded-full object-cover" />
                <div>
                  <p class="text-sm font-bold text-navy-900">{t.name}</p>
                  <p class="text-xs text-navy-600">{t.role}</p>
                </div>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-navy-50/50 py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 class="text-center text-3xl font-extrabold tracking-tight text-navy-900 sm:text-4xl">
        Frequently asked questions
      </h2>
      <div class="mt-10 space-y-4">
        {
          faqs.map((f) => (
            <details class="group rounded-2xl border border-navy-100 bg-white p-6 shadow-sm">
              <summary class="flex cursor-pointer list-none items-center justify-between text-base font-bold text-navy-900">
                {f.q}
                <span class="ml-4 text-brand-500 transition group-open:rotate-45">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" d="M12 5v14M5 12h14" />
                  </svg>
                </span>
              </summary>
              <p class="mt-3 text-sm leading-7 text-navy-700">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

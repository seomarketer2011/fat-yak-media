---
import { Image } from 'astro:assets';
import type { Service } from '../data/services';

interface Props {
  service: Service;
}
const { service } = Astro.props;

const icons = import.meta.glob<{ default: ImageMetadata }>('../assets/icons/*.png');
const icon = await icons[`../assets/icons/${service.icon}.png`]();
---

<a
  href={`/services/${service.slug}/`}
  class="group flex flex-col rounded-2xl border border-navy-100 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:border-brand-300 hover:shadow-lg"
>
  <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-brand-50 p-3 transition group-hover:bg-brand-100">
    <Image src={icon.default} alt="" width="80" height="80" class="h-10 w-10 object-contain" />
  </div>
  <h3 class="mt-5 text-lg font-bold text-navy-900 group-hover:text-brand-600">{service.title}</h3>
  <p class="mt-2 flex-1 text-sm leading-6 text-navy-700">{service.excerpt}</p>
  <span class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-brand-500">
    Learn more
    <svg class="h-4 w-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5-5 5M6 12h12" />
    </svg>
  </span>
</a>

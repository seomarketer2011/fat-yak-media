---
import Base from '../../layouts/Base.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CtaBand from '../../components/CtaBand.astro';
import { SERVICES } from '../../data/services';
import { SITE } from '../../data/site';
---

<Base
  title={`Services — ${SITE.name}`}
  description="Local SEO, search engine optimisation, web design, social media, Google Ads and content marketing for local businesses."
>
  <section class="bg-navy-950 py-16">
    <div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
      <p class="text-sm font-bold uppercase tracking-widest text-teal-400">Services</p>
      <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
        Everything your business needs to grow online
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-navy-200">
        Start with the service that hurts most, or combine them into a complete local growth engine.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto grid max-w-6xl gap-6 px-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-3">
      {SERVICES.map((service) => <ServiceCard service={service} />)}
    </div>
  </section>

  <CtaBand />
</Base>

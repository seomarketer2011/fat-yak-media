---
import { NAV_LINKS, SITE } from '../data/site';
import Logo from './Logo.astro';

const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="sticky top-0 z-50 border-b border-navy-100 bg-white/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2" aria-label={`${SITE.name} home`}>
      <Logo class="h-9 w-9" />
      <span class="text-lg font-extrabold tracking-tight text-navy-900">
        Fat Yak <span class="text-brand-500">Media</span>
      </span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-semibold transition-colors hover:text-brand-500',
              isActive(link.href) ? 'text-brand-600' : 'text-navy-800',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/contact/"
        class="rounded-full bg-amber-500 px-5 py-2.5 text-sm font-bold text-navy-950 shadow-sm transition hover:bg-amber-400"
      >
        Free SEO Audit
      </a>
    </nav>

    <button
      id="menu-toggle"
      class="inline-flex items-center justify-center rounded-md p-2 text-navy-800 hover:bg-navy-50 md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden border-t border-navy-100 bg-white md:hidden" aria-label="Mobile">
    <div class="space-y-1 px-4 py-3">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'block rounded-md px-3 py-2 text-base font-semibold',
              isActive(link.href) ? 'bg-brand-50 text-brand-600' : 'text-navy-800 hover:bg-navy-50',
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/contact/"
        class="mt-2 block rounded-full bg-amber-500 px-5 py-2.5 text-center text-base font-bold text-navy-950"
      >
        Free SEO Audit
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
